<Window x:Class="CompanyDe.Views.Windows.EditUsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CompanyDe.Views.Windows"
        mc:Ignorable="d"
                Title="AddUsersWindow" SizeToContent="WidthAndHeight">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="5" />
            <RowDefinition Height="50" />
            <RowDefinition Height="5" />
            <RowDefinition Height="50" />
            <RowDefinition Height="5" />
            <RowDefinition Height="50" />
            <RowDefinition Height="5" />
            <RowDefinition Height="50" />
            <RowDefinition Height="5" />
            <RowDefinition Height="50" />
            <RowDefinition Height="5" />
            <RowDefinition Height="50" />
            <RowDefinition Height="5" />
            <RowDefinition Height="50" />
            <RowDefinition Height="5" />
            <RowDefinition Height="50" />
            <RowDefinition Height="5" />
            <RowDefinition Height="50" />
            <RowDefinition Height="5" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <TextBlock Text="Полное имя:" />
        <TextBox Name="NameTb" Grid.Column="2" Text="{Binding Name}"/>

        <TextBlock Grid.Row="2" Text="ИНН:" />
        <TextBox Name="InnTb" Grid.Row="2" Grid.Column="2" Text="{Binding INN}"/>

        <TextBlock Grid.Row="4" Text="Адресс:" />
        <TextBox Name="AdressTb" Grid.Row="4" Grid.Column="2" Text="{Binding Addres}"/>

        <TextBlock Grid.Row="6" Text="Телефон:" />
        <TextBox Name="PhoneTb" Grid.Row="6" Grid.Column="2" Text="{Binding Phone}"/>

        <CheckBox Name="IsSalesmanCb" Grid.Row="8" Grid.Column="2" Content="Является продавцом"/>
        <CheckBox Name="IsBuyerCb" Grid.Row="10" Grid.Column="2" Content="Является покупателем"/>

        <TextBlock Grid.Row="12" Text="Логин:" />
        <TextBox Name="LoginTb" Grid.Row="12" Grid.Column="2" />

        <TextBlock Grid.Row="14" Text="Пароль:" />
        <TextBox Name="PassTb" Grid.Row="14" Grid.Column="2" />

        <CheckBox Name="IsBlockedCb" Grid.Row="16" Grid.Column="2" Content="Заблокирован"/>

        <TextBlock Grid.Row="18" Text="Роль:" />
        <ComboBox Name="RoleCmb" Grid.Row="18" Grid.Column="2" SelectedValuePath="Id" DisplayMemberPath="Name"/>
        <Button Grid.Row=" 20" Grid.Column="2" Content="Редактировать" Name="EditBtn" Click="EditBtn_Click"/>
    </Grid>
</Window>

